---
import { Image } from 'astro:assets';
import whyAttendPhoto from '../assets/local/Why Attend.png';

const features = [
  {
    title: 'AI-Native Development',
    body: 'Get hands on with bootcamps, learn about the latest AI developments, and discover eLearning opportunities to turn your proof-of-concepts into enterprise-grade production.',
  },
  {
    title: 'Invest in Your Growth',
    body: "Discover how AI is reshaping the developer toolkit and learn how to make it work for you. Explore new tools, pick up practical skills, and leave with ideas you'll actually use, whether it's for your next project or your next career move.",
  },
  {
    title: 'Hear from Industry Trailblazers',
    body: 'Get inspiration from industry luminaries, community leaders, and your peers. Hear their stories and see their innovations to inspire your own.',
  },
];
---

<section id="why-attend" class="why">
  <div class="why-inner">
    <h2 class="why-title">Why Attend</h2>

    <div class="why-grid">
      <div class="features">
        {
          features.map((f) => (
            <div class="feature">
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>
          ))
        }
      </div>

      <div class="why-photo">
        <Image
          src={whyAttendPhoto}
          alt="Attendees networking beneath MongoDB banners in the venue at a .local event"
          widths={[768, 1200, 1656]}
          sizes="(max-width: 1024px) 100vw, 55vw"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .why {
    background: #001e2b;
    color: #ffffff;
    /* No right padding on desktop so the photo bleeds to the viewport edge */
    padding: clamp(72px, 10vw, 140px) 0 clamp(72px, 10vw, 140px) clamp(16px, 8%, 132px);
  }

  .why-title {
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 500;
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.14;
    color: #ffffff;
    margin: 0 0 clamp(40px, 6vw, 72px);
    padding-right: clamp(16px, 8%, 132px);
  }

  .why-grid {
    display: grid;
    grid-template-columns: minmax(0, 696px) 1fr;
    align-items: stretch;
    gap: clamp(24px, 4vw, 64px);
  }

  .features {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .feature {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
  }

  .feature:first-child {
    padding-top: 32px;
  }

  .feature:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .feature h3 {
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 600;
    font-size: clamp(24px, 3.2vw, 32px);
    line-height: 1.25;
    color: #ffffff;
    margin: 0;
  }

  .feature p {
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 32px;
    color: #b8c4c2;
    max-width: 576px;
    margin: 0;
  }

  .why-photo {
    position: relative;
    overflow: hidden;
    /* Rounded on the left only; right edge runs off the viewport */
    border-radius: 8px 0 0 8px;
  }

  .why-photo :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 1024px) {
    .why {
      /* Restore symmetric padding once the photo stacks below */
      padding-right: clamp(16px, 8%, 132px);
    }

    .why-grid {
      grid-template-columns: 1fr;
      gap: clamp(32px, 6vw, 56px);
    }

    .why-photo {
      border-radius: 8px;
      aspect-ratio: 16 / 10;
    }
  }
</style>
