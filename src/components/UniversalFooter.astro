---
import MongoLogo from './MongoLogo.astro';

const columns = [
  {
    heading: 'About',
    links: [
      'Careers',
      'Investor Relations',
      'Legal',
      'Github',
      'Security Information',
      'Trust Center',
      'Connect with us',
    ],
  },
  {
    heading: 'Support',
    links: ['Contact Us', 'Customer Portal', 'Atlas Status', 'Customer Support', 'Manage Cookies'],
  },
  {
    heading: 'Deployment Options',
    links: ['MongoDB Atlas', 'Enterprise Advanced', 'Community Edition'],
  },
  {
    heading: 'Data Basics',
    links: [
      'Vector Databases',
      'NoSQL Databases',
      'Document Databases',
      'RAG Database',
      'ACID Transactions',
      'MERN Stack',
      'MEAN Stack',
    ],
  },
];
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-cols">
      <div class="footer-brand">
        <MongoLogo class="footer-logo" />

        <button class="lang" type="button" aria-label="Select language: English">
          <svg class="lang-globe" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="1.3" />
            <path
              d="M1.5 9h15M9 1.5c2.2 2.3 2.2 11.7 0 15M9 1.5c-2.2 2.3-2.2 11.7 0 15"
              stroke="currentColor"
              stroke-width="1.3"
            />
          </svg>
          <span>English</span>
          <svg class="lang-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path
              d="M4 6l4 4 4-4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </button>
      </div>

      {
        columns.map((col) => (
          <nav class="footer-col" aria-label={col.heading}>
            <h3 class="footer-heading">{col.heading}</h3>
            <ul class="footer-links">
              {col.links.map((link) => (
                <li>
                  <a href="#">{link}</a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <p class="footer-copy">© 2026 MongoDB, Inc.</p>
  </div>
</footer>

<style>
  .footer {
    background: #061621;
    color: #ffffff;
    padding: 64px clamp(16px, 8%, 132px);
  }

  .footer-inner {
    max-width: 1416px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 40px;
    align-items: start;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .footer-logo {
    width: 200px;
    max-width: 100%;
    height: auto;
    color: #ffffff;
  }

  .lang {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 16px;
    padding: 16px 0;
    background: none;
    border: 0;
    cursor: pointer;
    color: #ffffff;
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 24px;
    transition: color var(--flora-motion-duration-feedback) var(--flora-motion-easing-feedback);
  }

  .lang:hover {
    color: #00ed64;
  }

  .lang svg {
    flex-shrink: 0;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .footer-heading {
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 600;
    font-size: 16px;
    line-height: 16px;
    color: #ffffff;
    margin: 0;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .footer-links a {
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.4;
    color: #ffffff;
    text-decoration: none;
    transition: color var(--flora-motion-duration-feedback) var(--flora-motion-easing-feedback);
  }

  .footer-links a:hover {
    color: #00ed64;
  }

  .footer-copy {
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.4;
    color: #b8c4c2;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .footer-cols {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 48px 40px;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .footer-cols {
      grid-template-columns: 1fr;
    }
  }
</style>
