---
import { Image } from 'astro:assets';
import whyAttendPhoto from '../assets/local/tickets.png';

const reasons = [
  {
    area: 'r1',
    index: '01',
    title: 'Get hands-on with AI',
    body: 'Bootcamps, labs, and eLearning that take proof-of-concepts to production, on the latest from MongoDB and Voyage AI.',
  },
  {
    area: 'r2',
    index: '02',
    title: 'Invest in how you build',
    body: "See how AI is reshaping the developer toolkit, and leave with skills you'll use on your next project.",
  },
  {
    area: 'r3',
    index: '03',
    title: 'Learn from the people shipping it',
    body: 'Industry luminaries, community leaders, and the peers in your field, sharing the real decisions behind their work.',
  },
];
---



<section id="why-attend-bento" class="why">
  <div class="why-head">
    <h2 class="why-title" data-reveal>Worth stepping away from the keyboard for.</h2>
    <p class="why-lede" data-reveal style="--reveal-delay: 90ms">
      One day at The Midway with the engineers, founders, and architects putting AI
      into production, plus the hands-on time to take it back to your own stack.
    </p>
  </div>
  <div class="why-inner">
    <div class="why-grid">
      <div class="bento">

        {
          reasons.map((r, i) => (
            <article
              class={`tile tile-reason tile-${r.area}`}
              data-reveal
              style={`--reveal-delay: ${120 + i * 90}ms`}
            >
              <span class="reason-index" aria-hidden="true">
                {r.index}
              </span>
              <div class="reason-text">
                <h3 class="reason-title">{r.title}</h3>
                <p class="reason-body">{r.body}</p>
              </div>
            </article>
          ))
        }

        <a class="tile tile-meta" href="#pricing" data-reveal style="--reveal-delay: 210ms">
          <span class="meta-label">Where and when</span>
          <span class="meta-place">The Midway, San Francisco</span>
          <span class="meta-date">August 13, 2026</span>
          <span class="meta-cta">
            See ticket options
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      </div>

      <div class="why-photo" data-reveal-photo style="--reveal-delay: 160ms">
        <Image
          src={whyAttendPhoto}
          alt="Attendees gathered in the venue beneath MongoDB banners at a .local event"
          widths={[768, 1200, 1656]}
          sizes="(max-width: 1024px) 100vw, 42vw"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>

<script>
  // Same progressive-enhancement pattern as the first variation: visible
  // without JS, reveal only opts in once JS confirms it can run.
  const section = document.getElementById('why-attend-bento');
  if (section) {
    section.classList.add('js-ready');
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            obs.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15 },
    );
    io.observe(section);
  }
</script>

<style>
  .why {
    /* No right padding on desktop so the photo bleeds to the viewport edge */
    padding: clamp(72px, 10vw, 128px) 0 clamp(72px, 10vw, 128px) clamp(16px, 8%, 132px);
  }

  .why-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.78fr);
    align-items: stretch;
    gap: clamp(16px, 2.2vw, 28px);
  }

  .why-head {
    max-width: 1176px;
    margin: 0 0 clamp(48px, 7vw, 88px);
    padding-right: clamp(16px, 8%, 132px);
  }

  .why-title {
    font-family: 'MongoDB Value Serif', Georgia, serif;
    font-weight: 400;
    font-size: clamp(40px, 6vw, 68px);
    line-height: 1.08;
    letter-spacing: -0.01em;
    text-wrap: balance;
    color: #ffffff;
    margin: 0;
  }

  .why-lede {
    margin: clamp(20px, 2.5vw, 28px) 0 0;
    max-width: 620px;
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 400;
    font-size: clamp(18px, 1.6vw, 21px);
    line-height: 1.6;
    color: #b8c4c2;
    text-wrap: pretty;
  }

  /* ---- Bento ------------------------------------------------------------ */
  .bento {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: auto minmax(0, 1fr) auto auto;
    grid-template-areas:
      'head head'
      'r1   r2'
      'meta meta'
      'r3   r3';
    gap: clamp(12px, 1.4vw, 20px);
  }

  .tile {
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    padding: clamp(22px, 2.2vw, 34px);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .tile-head {
    grid-area: head;
    background: #023430; /* forest deep */
    gap: clamp(14px, 1.4vw, 20px);
  }

  .head-title {
    font-family: 'MongoDB Value Serif', Georgia, serif;
    font-weight: 400;
    font-size: clamp(28px, 3vw, 42px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    text-wrap: balance;
    color: #ffffff;
    margin: 0;
    max-width: 18ch;
  }

  .head-lede {
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 400;
    font-size: clamp(16px, 1.2vw, 18px);
    line-height: 1.6;
    color: #b8c4c2;
    margin: 0;
    max-width: 46ch;
    text-wrap: pretty;
  }

  .tile-reason {
    gap: clamp(16px, 2vw, 28px);
  }

  .reason-text {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .tile-r1 {
    grid-area: r1;
    background: #21313C;
    justify-content: space-between;
  }

  .tile-r2 {
    grid-area: r2;
    background: #21313C;
  }

  .tile-r3 {
    grid-area: r3;
    background: #21313C;
  }

  .reason-index {
    font-family: 'MongoDB Value Serif', Georgia, serif;
    font-weight: 400;
    font-size: clamp(34px, 3.4vw, 48px);
    line-height: 0.9;
    color: #00ed64;
    font-variant-numeric: tabular-nums;
    margin-bottom: clamp(8px, 1.4vw, 18px);
  }

  .tile-r1 .reason-index {
    margin-bottom: 0;
  }

  .reason-title {
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 600;
    font-size: clamp(19px, 1.8vw, 32px);
    line-height: 1.22;
    color: #ffffff;
    margin: 0;
    text-wrap: balance;
  }

  .reason-body {
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.6;
    color: #b8c4c2;
    margin: 0;
  }

  /* Green logistics tile: the one charged-signal moment in the bento */
  .tile-meta {
    grid-area: meta;
    background: #00ed64;
    border-color: transparent;
    color: #001e2b;
    text-decoration: none;
    gap: 4px;
    justify-content: center;
    transition:
      transform var(--flora-motion-duration-enter) var(--flora-motion-easing-emphasized),
      box-shadow var(--flora-motion-duration-moderate) var(--flora-motion-easing-emphasized);
  }

  .meta-label {
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 1.4;
    color: #023430;
  }

  .meta-place {
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 600;
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.25;
    color: #001e2b;
    margin-top: 8px;
  }

  .meta-date {
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.4;
    color: #023430;
  }

  .meta-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: clamp(10px, 1.4vw, 18px);
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 600;
    font-size: 15px;
    color: #001e2b;
  }

  .meta-cta svg {
    transition: transform var(--flora-motion-duration-enter) var(--flora-motion-easing-emphasized);
  }

  .tile-meta:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 0 6px color-mix(in oklch, #00ed64 35%, transparent);
  }

  .tile-meta:hover .meta-cta svg {
    transform: translateX(4px);
  }

  /* Keyboard focus: a white ring reads against both the green tile and the
     navy section gutter (a deep-space ring would vanish on the navy). */
  .tile-meta:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: 3px;
  }

  /* ---- Photo ------------------------------------------------------------ */
  .why-photo {
    position: relative;
    overflow: hidden;
    border-radius: 16px 0 0 16px;
    min-height: 420px;
  }

  .why-photo :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ---- Reveal (enhancement only, safe without JS / reduced motion) ------ */
  @media (prefers-reduced-motion: no-preference) {
    .why.js-ready [data-reveal],
    .why.js-ready [data-reveal-photo] {
      opacity: 0;
      transition:
        opacity 620ms var(--flora-motion-easing-expressive),
        transform 620ms var(--flora-motion-easing-expressive);
      transition-delay: var(--reveal-delay, 0ms);
    }

    .why.js-ready [data-reveal] {
      transform: scale(0.96) translateY(12px);
    }

    .why.js-ready [data-reveal-photo] {
      transform: scale(1.06);
    }

    .why.js-ready.in-view [data-reveal],
    .why.js-ready.in-view [data-reveal-photo] {
      opacity: 1;
      transform: none;
    }

    /* Re-assert the hover lift above the in-view reset's specificity, so the
       green tile still responds once it has revealed. */
    .why.js-ready.in-view .tile-meta:hover {
      transform: translateY(-2px);
    }
  }

  @media (max-width: 1024px) {
    .why {
      padding-right: clamp(16px, 8%, 132px);
    }

    .why-grid {
      grid-template-columns: 1fr;
      gap: clamp(20px, 4vw, 32px);
    }

    .bento {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-rows: none;
      grid-template-areas:
        'head head'
        'r1   r2'
        'r3   meta';
    }

    .why-photo {
      grid-row: 1;
      border-radius: 16px;
      aspect-ratio: 16 / 10;
      min-height: 0;
    }
  }

  @media (max-width: 560px) {
    .bento {
      grid-template-columns: 1fr;
      grid-template-areas:
        'head'
        'r1'
        'r2'
        'r3'
        'meta';
    }
  }
</style>
