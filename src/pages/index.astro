---
import Layout from '../layouts/Layout.astro';
import HeroNav from '../components/HeroNav.svelte';
import CountdownWatch from '../components/CountdownWatch.svelte';
import WhyAttend from '../components/WhyAttend.astro';
import WhyAttendBento from '../components/WhyAttendBento.astro';
import FeaturedSpeakers from '../components/FeaturedSpeakers.astro';
import TicketPricing from '../components/TicketPricing.astro';
import FeaturedSessions from '../components/FeaturedSessions.astro';
import PromoBanner from '../components/PromoBanner.astro';
import GlobalSponsors from '../components/GlobalSponsors.astro';
import Faq from '../components/Faq.astro';
import Endcap from '../components/Endcap.astro';
import UniversalFooter from '../components/UniversalFooter.astro';
import ReviewAnnotations from '../components/ReviewAnnotations.svelte';
---

<Layout title="MongoDB .local San Francisco · 2026">
  <HeroNav client:only="svelte" />
  <CountdownWatch client:load />

  <main id="main-content">
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <video
        class="hero-bg-media"
        src="/hero/video.mp4"
        poster="/hero/bg-hero.png"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      ></video>
      <div class="hero-bg-overlay"></div>
    </div>

    <div class="hero-content">
      <div class="eyebrow">
        <span>The Midway, San Francisco</span>
        <span class="dot" aria-hidden="true">•</span>
        <span>August 13, 2026</span>
      </div>

      <h1 class="headline">
        Ship your AI<br />
        vision, faster.
      </h1>

      <p class="lede">
        Join the Bay Area's top leaders, founders, and experts for a day of knowledge
        sharing and networking. You'll master new tech, gain a fresh vision of success,
        and see the latest from MongoDB and Voyage AI.
      </p>

      <div class="cta-row">
        <a class="btn btn-primary" href="#register">Register Now</a>
        <a class="btn btn-secondary" href="#agenda">View Agenda</a>
      </div>
    </div>

    <a class="scroll-cue" href="#why-attend-bento" aria-label="Scroll to why attend">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none">
        <circle cx="12" cy="12" r="10" stroke="#ffffff" stroke-width="2" />
        <path d="M16 10L12 14L8 10" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
  </section>
  
    <!-- <WhyAttend /> -->
    <WhyAttendBento />
    <FeaturedSpeakers />
    <FeaturedSessions />
    <TicketPricing />
    <PromoBanner />
    <GlobalSponsors />
    <Faq />
    <Endcap />
  </main>

  <UniversalFooter />

  {import.meta.env.DEV && <ReviewAnnotations client:only="svelte" />}
</Layout>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 640px;
    overflow: hidden;
    color: #ffffff;
    isolation: isolate;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 30, 43, 0.7);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 clamp(16px, 8%, 132px);
    gap: 16px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px;
    border: 1px solid #5d6c74;
    border-radius: 8px;
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 16px;
    color: #ffffff;
    background: rgba(0, 30, 43, 0.25);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .eyebrow .dot {
    color: #00ed64;
  }

  .headline {
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 400;
    font-size: clamp(48px, 7vw, 96px);
    line-height: 1.1;
    text-transform: uppercase;
    color: #ffffff;
    margin: 8px 0 0;
    letter-spacing: -0.01em;
  }

  .lede {
    margin: 24px 0 0;
    max-width: 696px;
    font-family: 'Euclid Circular A', sans-serif;
    font-size: 18px;
    line-height: 32px;
    color: #ededed;
  }

  .cta-row {
    margin-top: 32px;
    display: flex;
    gap: 24px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    border-radius: 4px;
    font-family: 'Euclid Circular A', sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 16px;
    text-decoration: none;
    border: 1px solid transparent;
    cursor: pointer;
    /* Flora button motion: feedback for color, emphasized movement for the
       hover lift + border-radius morph */
    transition:
      background var(--flora-motion-duration-feedback) var(--flora-motion-easing-feedback),
      color var(--flora-motion-duration-feedback) var(--flora-motion-easing-feedback),
      border-color var(--flora-motion-duration-feedback) var(--flora-motion-easing-feedback),
      box-shadow var(--flora-motion-duration-moderate) var(--flora-motion-easing-emphasized),
      transform var(--flora-motion-duration-enter) var(--flora-motion-easing-emphasized),
      border-radius var(--flora-motion-duration-enter) var(--flora-motion-easing-emphasized);
  }

  .btn:hover {
    transform: translateY(-1px);
    border-radius: var(--radius-border-radius-circle);
  }

  .btn:active {
    transform: scale(0.985);
    border-radius: var(--radius-border-radius-circle);
    /* Press should feel instant */
    transition-duration: var(--flora-motion-duration-instant);
  }

  .btn-primary {
    background: #00ed64;
    color: #001e2b;
    border-color: #00684a;
  }

  .btn-primary:hover {
    background: #00d959;
    box-shadow: 0 0 0 6px color-mix(in oklch, #00ed64 45%, transparent);
  }

  .btn-secondary {
    background: transparent;
    color: #ffffff;
    border-color: #ffffff;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 0 0 6px color-mix(in oklch, #ffffff 18%, transparent);
  }

  .scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 16px;
    transform: translateX(-50%);
    z-index: 1;
    animation: bob 2.4s ease-in-out infinite;
    color: #ffffff;
  }

  @keyframes bob {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 6px); }
  }
</style>
